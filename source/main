// =============================================================================
// 10. MAIN PAGE WRAPPER COMPONENTS
// =============================================================================

/**
 * Wrapper for the Landing Page content.
 */
const LandingPage = ({ onNavigate }) => (
  <>
    <Hero onNavigate={onNavigate} />
    <Wizard />
    <Services />
    <Industries />
    <Cases onNavigate={onNavigate} />
    <Stats />
    <LatestInsights onNavigate={onNavigate} />
    <Contact />
  </>
);

/**
 * Main Application Component (The root).
 */
export default function App() {
  const [currentPage, setCurrentPage] = useState('home');

  // Cal.com Embed Initialization
  useEffect(() => {
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, arguments) : p(cal, arguments); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", {origin:"https://cal.com"});
    Cal("ui", {"styles":{"branding":{"brandColor":"#0062D1"}},"hideEventTypeDetails":false,"layout":"month_view"});
  }, []);

  // Scroll to top whenever page changes
  useEffect(() => {
    window.scrollTo(0, 0);
  }, [currentPage]);

  /**
   * Renders the appropriate page component based on the current page state.
   */
  const renderPage = () => {
    switch(true) {
      case currentPage === 'home': return <LandingPage onNavigate={setCurrentPage} />;
      case typeof currentPage === 'string' && currentPage.startsWith('case:'): 
        const caseId = currentPage.split(':')[1];
        return <CaseStudyDetail id={caseId} onNavigate={setCurrentPage} />;
      case currentPage === 'cases': return <CasesPage onNavigate={setCurrentPage} />;
      case currentPage === 'contact': return <div className="pt-20"><Contact /></div>;
      case currentPage === 'insights': return <InsightsPage onNavigate={setCurrentPage} />;
      case currentPage.startsWith('service-'): return <PageLayout title={currentPage.replace('service-', '').replace('-', ' ').toUpperCase()} subtitle="Dedicated service page." />;
      case currentPage.startsWith('company-'): return <PageLayout title={currentPage.replace('company-', '').replace('-', ' ').toUpperCase()} subtitle="Learn more about our company." />;
      default: return <LandingPage onNavigate={setCurrentPage} />;
    }
  };

  return (
    <div className="min-h-screen bg-white font-sans text-[#0F172A] selection:bg-[#0062D1] selection:text-white">
      <GlobalStyles />
      <Navbar onNavigate={setCurrentPage} currentPage={currentPage} />
      <main>
        {renderPage()}
      </main>
      <Footer onNavigate={setCurrentPage} />
    </div>
  );
}