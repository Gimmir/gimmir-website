/**
 * Article Card Component (Used on InsightsPage for detailed grid layout).
 */
const ArticleCard = ({ post, index, onNavigate, featured = false }) => {
    
    // Featured Post Style
    if (featured) {
        return (
            <FadeIn delay={100} className="lg:col-span-3 h-full">
                <div className="group relative bg-white rounded-3xl border border-gray-200 hover:border-[#0062D1] transition-all duration-500 cursor-pointer overflow-hidden shadow-lg hover:shadow-xl">
                    {/* Image */}
                    <div className="relative h-96 overflow-hidden">
                        <img 
                            src={post.image} 
                            alt={post.title} 
                            className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                        />
                        <div className="absolute inset-0 bg-gray-900/10" />
                    </div>
                    {/* Content */}
                    <div className="p-6 md:p-8 flex flex-col">
                        <div className="flex items-center gap-3 mb-4 border-b border-gray-100 pb-4">
                            <span className="px-3 py-1 rounded-full bg-[#0062D1] text-white text-[9px] font-bold uppercase tracking-wider shadow-md">Featured</span>
                            <span className="text-[10px] font-bold text-gray-500 uppercase tracking-widest">{post.category} | {post.date}</span>
                        </div>
                        <h3 className="text-3xl md:text-4xl font-bold text-[#0F172A] leading-tight mb-4 group-hover:text-[#0062D1] transition-colors">{post.title}</h3>
                        <p className="text-gray-600 text-lg leading-relaxed mb-6 flex-1">{post.summary}</p>
                        <div className="mt-auto">
                            <button className="flex items-center gap-2 text-base font-bold text-[#0062D1] hover:text-[#0F172A] transition-colors">
                                Read Full Report <ArrowRight size={16} className="transform translate-x-0 group-hover:translate-x-1 transition-transform" />
                            </button>
                        </div>
                    </div>
                </div>
            </FadeIn>
        );
    }
    
    // Default Grid Card Style
    return (
        <FadeIn delay={index * 150} className="h-full">
            <div className="group bg-white border border-gray-200 rounded-2xl overflow-hidden hover:border-[#0062D1] transition-all duration-300 flex flex-col h-full cursor-pointer">
                <div className="relative h-48 overflow-hidden">
                    <img src={post.image} alt={post.title} className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                </div>
                <div className="p-6 flex-1 flex flex-col">
                    <div className="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">{post.category} | {post.date}</div>
                    <h3 className="text-xl font-bold text-[#0F172A] leading-tight mb-3 group-hover:text-[#0062D1] transition-colors">{post.title}</h3>
                    <p className="text-gray-600 text-sm leading-relaxed mb-6 flex-1 line-clamp-3">{post.summary}</p>
                    <div className="mt-auto">
                        <button className="flex items-center gap-2 text-sm font-bold text-[#0062D1] hover:text-[#0F172A] transition-colors">
                            Read Article <ArrowRight size={14} className="transform translate-x-0 group-hover:translate-x-1 transition-transform" />
                        </button>
                    </div>
                </div>
            </div>
        </FadeIn>
    );
};

/**
 * Dedicated Insights/Blog Page Component.
 */
const InsightsPage = ({ onNavigate }) => {
  const [filter, setFilter] = useState('All');
  const [searchTerm, setSearchTerm] = useState('');

  const filteredPosts = ALL_POSTS.filter(p => {
    const categoryMatch = filter === 'All' || p.category === filter;
    const searchMatch = p.title.toLowerCase().includes(searchTerm.toLowerCase()) || p.summary.toLowerCase().includes(searchTerm.toLowerCase());
    return categoryMatch && searchMatch;
  });
  
  const featuredPost = filteredPosts.length > 0 ? filteredPosts[0] : null;
  const remainingPosts = filteredPosts.slice(1);

  return (
    <div className="pt-24 md:pt-32 min-h-screen bg-gray-50">
        <div className="container mx-auto px-4 md:px-6 pb-20">
            <SectionHeading 
                label="Knowledge Base" 
                title="Engineering Insights & Tech Deep Dives" 
                subtitle="Explore our library of technical articles, case studies, and industry analysis authored by Gimmir's lead experts." 
                center 
            />

            {/* Search and Filter Bar */}
            <FadeIn delay={200}>
                <div className="max-w-6xl mx-auto mb-10 md:mb-16">
                    <div className="flex flex-col md:flex-row items-center gap-4 md:gap-6 bg-white p-4 md:p-6 rounded-2xl border border-gray-100 shadow-xl">
                        
                        {/* Search Input */}
                        <div className="relative w-full md:w-1/3 shrink-0">
                            <Search size={18} className="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400" />
                            <input
                                type="text"
                                placeholder="Search articles..."
                                value={searchTerm}
                                onChange={(e) => setSearchTerm(e.target.value)}
                                className="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-xl font-medium focus:ring-0 focus:border-[#0062D1] outline-none transition-all duration-300"
                            />
                        </div>
                        
                        {/* Category Filters */}
                        <div className="w-full md:w-2/3 overflow-x-auto hide-scrollbar flex justify-start md:justify-start">
                            <div className="flex flex-nowrap gap-2 p-0 rounded-xl">
                                {ALL_CATEGORIES.map(category => (
                                    <button 
                                        key={category} 
                                        onClick={() => setFilter(category)}
                                        className={`px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-300 whitespace-nowrap ${
                                            filter === category 
                                                ? 'text-[#0062D1] border-b-2 border-[#0062D1] bg-transparent' 
                                                : 'text-gray-600 hover:text-[#0062D1] border-b-2 border-transparent hover:border-gray-300'
                                        }`}
                                    >
                                        {category}
                                    </button>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </FadeIn>


            {/* Articles Grid */}
            {filteredPosts.length > 0 ? (
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8 mb-20">
                    {/* Featured Post */}
                    {featuredPost && (
                        <ArticleCard 
                            key={featuredPost.id} 
                            index={0} 
                            post={featuredPost} 
                            onNavigate={onNavigate} 
                            featured={true}
                        />
                    )}

                    {/* Remaining Posts Grid */}
                    <div className="lg:col-span-3 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
                      {remainingPosts.map((post, idx) => (
                          <ArticleCard key={post.id} index={idx} post={post} onNavigate={onNavigate} featured={false} />
                      ))}
                    </div>
                </div>
            ) : (
                <div className="text-center py-20 text-gray-500 border border-gray-200 rounded-2xl bg-white">
                    <Search size={32} className="mx-auto mb-4" />
                    <p className="text-lg font-semibold">No articles found matching your criteria.</p>
                    <button onClick={() => {setFilter('All'); setSearchTerm('');}} className="mt-4 text-sm font-bold text-[#0062D1] hover:text-[#0F172A] transition-colors">Clear Filters</button>
                </div>
            )}
            
            {/* CTA Block */}
            <FadeIn delay={400}>
                <div className="relative p-6 md:p-12 bg-[#0F172A] rounded-2xl md:rounded-[2rem] text-center text-white overflow-hidden shadow-2xl shadow-gray-900/30 border border-white/10">
                    <div className="absolute inset-0 bg-[linear-gradient(rgba(0,98,209,0.1)_1px,transparent_1px),linear-gradient(90deg,rgba(0,98,209,0.1)_1px,transparent_1px)] bg-[size:30px_30px] opacity-10 mix-blend-overlay"></div>
                    <div className="relative z-10 max-w-2xl mx-auto">
                        <h3 className="text-2xl md:text-4xl font-bold mb-4 md:mb-6 leading-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-300 to-white">Can't find the topic you need?</h3>
                        <p className="text-gray-300 mb-8 text-base md:text-lg">Let's discuss your specific technical challenge directly with an architect. Book a consultation now.</p>
                        <div className="flex flex-col sm:flex-row justify-center gap-4">
                            <Button variant="primary" className="!py-4 !px-8 text-base shadow-xl hover:shadow-2xl hover:scale-105 transition-all w-full sm:w-auto" onClick={() => onNavigate('contact')}>Start Project Discussion</Button>
                            <Button 
                                variant="outline" 
                                className="!py-4 !px-8 text-base text-white border border-white/30 hover:bg-white/10 w-full sm:w-auto" 
                                data-cal-link="nazar-moroz/first-touch"
                                data-cal-config='{"layout":"month_view"}'
                            >
                                Book a Tech Meet
                            </Button>
                        </div>
                    </div>
                </div>
            </FadeIn>
        </div>
    </div>
  );
};


