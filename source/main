/**
 * Case Study Detail Page Component.
 */
const CaseStudyDetail = ({ id, onNavigate }) => {
  const data = ALL_CASES.find(c => c.id === id);
  
  const otherCases = ALL_CASES.filter(c => c.id !== id).slice(0, 2);

  if (!data) return <div className="pt-40 text-center">Case study not found. <button onClick={() => onNavigate('cases')} className="text-blue-600">Back to Cases</button></div>;

  return (
    <article className="min-h-screen bg-white">
      {/* Hero Section */}
      <section className="relative pt-40 pb-20 md:pb-32 bg-[#0B101B] text-white overflow-hidden">
        <div className="absolute inset-0">
           <img src={data.image} alt={data.title} className="w-full h-full object-cover opacity-20" />
           <div className="absolute inset-0 bg-gradient-to-b from-[#0B101B] via-[#0B101B]/90 to-[#0B101B]" />
        </div>
        <div className="container mx-auto px-6 relative z-10">
           <button onClick={() => onNavigate('cases')} className="flex items-center gap-2 text-blue-300 hover:text-white mb-8 text-sm font-bold uppercase tracking-wider transition-colors">
              <ArrowRight size={16} className="rotate-180" /> Back to Stories
           </button>
           <FadeIn>
             <div className="flex flex-wrap gap-3 mb-6">
                {data.tags.map(t => <span key={t} className="px-3 py-1 rounded-full border border-white/20 bg-white/5 text-xs font-bold uppercase tracking-wider text-blue-200">{t}</span>)}
             </div>
             <h1 className="text-4xl md:text-6xl lg:text-7xl font-bold mb-8 leading-tight max-w-4xl">{data.title}</h1>
             <div className="flex flex-col md:flex-row gap-8 md:gap-16 border-t border-white/10 pt-8">
                <div>
                   <div className="text-xs text-gray-400 uppercase tracking-widest mb-1">Client</div>
                   <div className="text-xl font-bold">{data.client}</div>
                </div>
                <div>
                   <div className="text-xs text-gray-400 uppercase tracking-widest mb-1">Industry</div>
                   <div className="text-xl font-bold">{data.industry}</div>
                </div>
             </div>
           </FadeIn>
        </div>
      </section>

      {/* Main Content */}
      <section className="py-20 md:py-24">
         <div className="container mx-auto px-6">
            <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
               
               {/* Left Content */}
               <div className="lg:col-span-8">
                  {/* About Client & Challenge */}
                  <FadeIn>
                     <div className="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
                        <div>
                           <h3 className="text-lg font-bold text-[#0F172A] mb-4 uppercase tracking-widest flex items-center gap-2"><div className="w-6 h-0.5 bg-[#0062D1]"/>About Client</h3>
                           <p className="text-gray-600 leading-relaxed">{data.aboutClient || "A confidential enterprise client seeking digital transformation to scale operations and improve customer experience."}</p>
                        </div>
                        <div>
                           <h3 className="text-lg font-bold text-[#0F172A] mb-4 uppercase tracking-widest flex items-center gap-2"><div className="w-6 h-0.5 bg-[#0062D1]"/>The Challenge</h3>
                           <p className="text-gray-600 leading-relaxed">{data.challenge}</p>
                        </div>
                     </div>
                  </FadeIn>

                  {/* Gallery / Mockups (If available) */}
                  {data.gallery && data.gallery.length > 0 && (
                    <FadeIn className="my-20">
                        <div className="rounded-2xl overflow-hidden shadow-2xl border border-gray-100 mb-8">
                            <img src={data.gallery[0]} className="w-full h-auto" alt="Main Interface" />
                        </div>
                        {data.gallery.length > 1 && (
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
                                {data.gallery.slice(1,3).map((img, idx) => (
                                    <div key={idx} className="rounded-2xl overflow-hidden shadow-xl border border-gray-100">
                                        <img src={img} className="w-full h-auto" alt={`Interface ${idx}`} />
                                    </div>
                                ))}
                            </div>
                        )}
                    </FadeIn>
                  )}

                  {/* Solution & Process */}
                  <FadeIn>
                     <h3 className="text-3xl font-bold text-[#0F172A] mb-8">Strategic Approach</h3>
                     <p className="text-lg text-gray-600 leading-relaxed mb-12">{data.solution}</p>
                     
                     {/* Process Steps */}
                     {data.process && (
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
                            {data.process.map((step, i) => {
                                const StepIcon = step.icon;
                                return (
                                <div key={i} className="p-6 bg-gray-50 rounded-xl border border-gray-100">
                                    <div className="w-10 h-10 rounded-lg bg-white border border-gray-200 flex items-center justify-center text-[#0062D1] mb-4 shadow-sm">
                                        <StepIcon size={20} />
                                    </div>
                                    <h4 className="font-bold text-[#0F172A] mb-2">{step.title}</h4>
                                    <p className="text-sm text-gray-500">{step.desc}</p>
                                </div>
                                )
                            })}
                        </div>
                     )}
                  </FadeIn>

                  {/* Results */}
                  <FadeIn className="bg-[#0F172A] text-white p-8 md:p-12 rounded-3xl relative overflow-hidden my-16">
                      <div className="absolute top-0 right-0 w-64 h-64 bg-[#0062D1] rounded-full blur-[100px] opacity-20" />
                      <h3 className="text-2xl font-bold mb-8 relative z-10">Key Outcomes</h3>
                      <div className="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
                          {data.metrics.map((m, i) => (
                              <div key={i}>
                                  <div className="text-4xl md:text-5xl font-bold text-[#0062D1] mb-2">{m.value}</div>
                                  <div className="text-sm text-gray-400 font-bold uppercase tracking-widest">{m.label}</div>
                              </div>
                          ))}
                      </div>
                  </FadeIn>

                  {/* Quote */}
                  {data.testimonial && (
                    <FadeIn className="border-l-4 border-[#0062D1] pl-8 py-2 my-12">
                        <p className="text-2xl font-medium text-[#0F172A] italic mb-6 leading-relaxed">"{data.testimonial.text}"</p>
                        <div className="flex items-center gap-3">
                            <div className="font-bold text-[#0F172A]">{data.testimonial.author}</div>
                        </div>
                    </FadeIn>
                  )}
               </div>

               {/* Right Sidebar */}
               <div className="lg:col-span-4">
                  <div className="sticky top-32 space-y-8">
                     {/* Tech Stack Widget */}
                     <FadeIn delay={200}>
                        <div className="bg-white rounded-2xl p-8 shadow-lg shadow-gray-100 border border-gray-100">
                           <h4 className="font-bold text-[#0F172A] mb-6 uppercase text-xs tracking-widest flex items-center gap-2">
                               <Cpu size={14} className="text-[#0062D1]" /> Technology Stack
                           </h4>
                           <div className="flex flex-wrap gap-2">
                              {data.techStack?.map(tech => (
                                 <span key={tech} className="px-3 py-1.5 bg-gray-50 border border-gray-200 rounded-md text-xs font-bold text-gray-600">
                                    {tech}
                                 </span>
                              ))}
                           </div>
                        </div>
                     </FadeIn>

                     {/* CTA Widget */}
                     <FadeIn delay={300}>
                        <div className="bg-[#0062D1] text-white rounded-2xl p-8 text-center relative overflow-hidden shadow-xl shadow-blue-900/20">
                           <div className="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
                           <div className="relative z-10">
                               <h4 className="text-xl font-bold mb-3">Ready for Impact?</h4>
                               <p className="text-blue-100 text-sm mb-6">Let's build a similar success story for your business.</p>
                               <Button variant="secondary" className="w-full justify-center" onClick={() => onNavigate('contact')}>Contact Us</Button>
                           </div>
                        </div>
                     </FadeIn>
                  </div>
               </div>

            </div>
         </div>
      </section>

      {/* Recent Cases Section */}
      <section className="py-16 bg-gray-50 border-t border-gray-200">
        <div className="container mx-auto px-6">
            <SectionHeading title="More Success Stories" subtitle="Explore other projects we have delivered." center />
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                {otherCases.map((c, idx) => (
                    <CaseCard key={c.id} index={idx} {...c} onNavigate={onNavigate} />
                ))}
            </div>
            <div className="mt-12 flex justify-center">
                <Button variant="outline" onClick={() => onNavigate('cases')}>View All Cases <ArrowRight size={16}/></Button>
            </div>
        </div>
      </section>

      {/* Contact Form at the bottom */}
      <Contact />
    </article>
  );
};


